{
  "name": "code-wiki",
  "version": "1.0.0",
  "description": "Cross-platform AI coding assistant enhancement — on-demand project context via MCP Server",
  "type": "module",
  "bin": {
    "code-wiki": "./dist/cli.js",
    "code-wiki-server": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
